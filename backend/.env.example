# Copy to backend/.env and fill in values.

# Cloudflare R2 — only required for /generate-avatar-full (SMPL-X pipeline).
# The dev stub /generate-avatar does not need R2.
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=vexa-assets
R2_PUBLIC_URL=

# Must match frontend's INTERNAL_SERVICE_TOKEN for Bearer verification.
INTERNAL_SERVICE_TOKEN=vx_internal_dev

# Where the Next.js frontend is served from. The stub avatar route returns
# `${NEXT_PUBLIC_APP_URL}/models/avatar.glb` as the avatar_url.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated additional CORS origins (frontend dev origins are added by default).
# ALLOWED_ORIGINS=https://staging.example.com,https://preview.example.com

# Path to SMPL-X model weights (.npz). Only needed for /generate-avatar-full.
SMPLX_MODEL_PATH=models/
