# VEXA Python Avatar Service Configuration

# Cloudflare R2
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=vexa-avatars
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# SMPL-X model weights — download from https://smpl-x.is.tue.mpg.de/
# Place in backend/models/ directory
SMPLX_MODEL_PATH=models/
HUGGINGFACE_API_KEY=

# Supabase (optional, if backend needs to update status directly)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Logging
LOG_LEVEL=INFO
INTERNAL_SERVICE_TOKEN=
