# Copy to .env.local and fill in values.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side: bypass RLS / admin writes (preferred for several API routes)
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Storage bucket for /api/tryon uploads (default: avatars). Create it in Dashboard → Storage if you see "Bucket not found".
SUPABASE_STORAGE_BUCKET=avatars

# IDM-VTON try-on runs on Hugging Face Inference API (model: yisol/IDM-VTON).
# Same key is used by backend video pipeline if you set it in backend/.env.
HUGGINGFACE_API_KEY=

# Meshy — proprietary Image-to-3D API for clothing GLBs (https://www.meshy.ai/)
MESHY_API_KEY=

# Python avatar service (video try-on dispatches POST /process-video here)
AVATAR_SERVICE_URL=http://127.0.0.1:8000

# Cloudflare R2 (uploads / CDN — see frontend/src/lib/r2.ts and api/user/delete)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=vexa-assets
R2_PUBLIC_URL=

# Optional: override default https://cdn.vexa.dev in avatarCache
# STORAGE_BASE_URL=

# Optional error reporting
# NEXT_PUBLIC_SENTRY_DSN=
