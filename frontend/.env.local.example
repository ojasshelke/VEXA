# Copy to .env.local and fill in values.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side: bypass RLS / admin writes (preferred for several API routes)
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Storage bucket for /api/tryon uploads (default: avatars). Create it in Dashboard → Storage if you see "Bucket not found".
SUPABASE_STORAGE_BUCKET=avatars



# Python avatar service (video try-on dispatches POST /process-video here)
AVATAR_SERVICE_URL=http://127.0.0.1:8000

# Cloudflare R2 (uploads / CDN — see frontend/src/lib/r2.ts and api/user/delete)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=vexa-assets
R2_PUBLIC_URL=

# Optional: override default https://cdn.vexa.dev in avatarCache
# STORAGE_BASE_URL=

# Hashed API key lookup — add your DEV key here for local testing only
DEV_API_KEY=vx_dev_local_only

# Optional error reporting
# NEXT_PUBLIC_SENTRY_DSN=

# Vitest / test environment
# No extra vars needed — uses same .env.local

# Internal onboarding bypass — set a secret value here, never 'onboarding' plaintext
INTERNAL_ONBOARDING_KEY=vx_internal_changeme

# Pillow / face texture pipeline (backend only, no frontend counterpart needed)
# No extra vars — face_texture uses R2_* vars already present above

FASHN_API_KEY=
NEXT_PUBLIC_APP_URL=
INTERNAL_SERVICE_TOKEN=vx_internal_secret_2024_vexa
FAL_KEY=    