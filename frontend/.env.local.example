# Copy to frontend/.env.local and fill in values.
# All NEXT_PUBLIC_* variables are shipped to the browser — never put secrets there.

# Supabase — get from supabase.com/dashboard/project/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only — bypasses RLS; required for routes that write on behalf of users.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Storage bucket used by try-on uploads (default: avatars).
# Create it in Dashboard → Storage if you see "Bucket not found".
SUPABASE_STORAGE_BUCKET=avatars

# HuggingFace — get from huggingface.co/settings/tokens
# Create a token named VEXA with "Read" permissions.
HUGGINGFACE_API_KEY=

# Meshy — Image-to-3D API for clothing GLBs (https://www.meshy.ai/)
MESHY_API_KEY=

# Cloudflare R2 — get from cloudflare.com/dashboard/r2
# R2 is optional for local dev — try-on results automatically fall back to inline base64.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=vexa-assets
R2_PUBLIC_URL=

# Python avatar backend — run with: cd backend && ./start.sh
# Either name is accepted; AVATAR_SERVICE_URL is the legacy name.
AVATAR_SERVICE_URL=http://127.0.0.1:8000
PYTHON_SERVICE_URL=http://127.0.0.1:8000
# Must match backend/.env INTERNAL_SERVICE_TOKEN. Any non-empty value works in dev.
INTERNAL_SERVICE_TOKEN=vx_internal_dev

# Public URL of this Next.js app. Used to build the placeholder GLB URL
# (`${NEXT_PUBLIC_APP_URL}/models/avatar.glb`) when the Python service is down.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: hashed API key lookup — dev-only key the marketplace auth accepts.
DEV_API_KEY=vx_dev_local_only

# Optional: internal onboarding bypass (legacy x-vexa-key flow).
# The current onboarding flow uses Supabase Bearer tokens, so this is unused.
INTERNAL_ONBOARDING_KEY=vx_internal_changeme

# Optional: override default https://cdn.vexa.dev in avatarCache
# STORAGE_BASE_URL=

# Optional error reporting
# NEXT_PUBLIC_SENTRY_DSN=
